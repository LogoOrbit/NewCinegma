# ──────────────────────────────────────────────────────────────
# Cinegma Films — environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to git.
# ──────────────────────────────────────────────────────────────

# Sanity CMS — get these from sanity.io/manage after creating a project
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=

# Resend — newsletter signups (resend.com → API Keys)
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# Plausible analytics — domain you registered at plausible.io
PUBLIC_PLAUSIBLE_DOMAIN=cinegmafilms.com

# Press kit / EPK gate — comma-separated allowed email domains, optional
EPK_ALLOWED_DOMAINS=

# Site URL (used for OG images, sitemap, RSS — no trailing slash)
PUBLIC_SITE_URL=https://cinegmafilms.com
